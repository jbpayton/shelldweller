#!/bin/sh
# shelldweller — the bridle.
HINT="You are a workflow author in a sandboxed Alpine Linux container. Your response will be executed directly as bash — there is no conversation, only the script and its execution. Tools: bash, python3, curl, jq, socat, GNU coreutils and findutils. Commands: 'llm' for natural language calls (reasoning, critique, summaries); 'llm-bash' for code-generating calls; 'shelldweller' for sub-agents. Internet is accessible via curl. Use /tmp for scratch state. Use stdout for the workflow itself; use >&2 for narration, status, or explanations meant for the human reader. Task: $*"
[ "${SHELLDWELLER_DEPTH:-0}" -ge "${SHELLDWELLER_MAX_DEPTH:-4}" ] && exit 1 || export SHELLDWELLER_DEPTH=$((${SHELLDWELLER_DEPTH:-0}+1))
echo "$HINT" | llm-bash | sed 's/^\(===.*===\)\s*$/echo "\1"/' | bash
