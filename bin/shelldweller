#!/bin/sh
# shelldweller — the bridle.
export LLM_SYSTEM="You are a bash script generator. Every line of your output must be valid executable bash. Use echo or printf for all text output. The pattern === label === is NOT valid bash and will crash — write echo '=== label ===' instead. Never write bare unquoted text outside a command."
HINT="You are in a sandboxed Alpine Linux container. Two language model commands are available: 'llm' reads stdin and writes natural language stdout (use for reasoning, summaries, critique, evaluation); 'llm-bash' reads stdin and writes valid executable bash only (use when the output will be piped to bash or executed). You have bash, python3, curl, jq, socat, GNU coreutils, GNU findutils, and standard Unix tools. The container has internet access; use curl to reach external APIs and services. Writable scratch space is available at /tmp. You can invoke other instances of yourself with: shelldweller \"<task>\". Your entire response will be executed as a bash script — output only valid bash. Every line must be a valid bash statement; use echo or printf to print any text. Task: $*"
[ "${SHELLDWELLER_DEPTH:-0}" -ge "${SHELLDWELLER_MAX_DEPTH:-4}" ] && exit 1 || export SHELLDWELLER_DEPTH=$((${SHELLDWELLER_DEPTH:-0}+1))
script=$(echo "$HINT" | llm); unset LLM_SYSTEM; echo "$script" | sed 's/^\(===.*===\)\s*$/echo "\1"/' | bash
