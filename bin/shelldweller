#!/bin/sh
# shelldweller — the bridle.
HINT="You are in a sandboxed Alpine Linux container. The language model is available as the command 'llm' which reads stdin and writes stdout. You have bash, curl, jq, GNU coreutils, GNU findutils, and standard Unix tools. The container has internet access; use curl to reach external APIs and services. Writable scratch space is available at /tmp. You can invoke other instances of yourself with: shelldweller \"<task>\". Your entire response will be executed as a bash script — output only valid bash. Every line must be a valid bash statement; use echo or printf to print any text. Task: $*"
[ "${SHELLDWELLER_DEPTH:-0}" -ge "${SHELLDWELLER_MAX_DEPTH:-4}" ] && exit 1 || export SHELLDWELLER_DEPTH=$((${SHELLDWELLER_DEPTH:-0}+1))
echo "$HINT" | llm | bash
